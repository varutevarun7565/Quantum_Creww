<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- JEEVAN — Light theme (used as the base XML wrapper for Compose) -->
    <style name="Theme.JEEVAN" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <!-- Primary brand color — Emergency Red -->
        <item name="colorPrimary">@color/jeevan_red</item>
        <item name="colorPrimaryVariant">@color/jeevan_red_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/jeevan_green</item>
        <item name="colorSecondaryVariant">@color/jeevan_green</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/jeevan_background</item>
        <item name="colorSurface">@color/jeevan_surface</item>
        <item name="colorOnSurface">@color/jeevan_on_bg</item>
        <item name="colorOnBackground">@color/jeevan_on_bg</item>

        <!-- Error -->
        <item name="colorError">@color/jeevan_red</item>
        <item name="colorOnError">@color/white</item>

        <!-- Status & nav bars -->
        <item name="android:statusBarColor">@color/jeevan_background</item>
        <item name="android:navigationBarColor">@color/jeevan_surface</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>

        <!-- No action bar (Compose handles all UI) -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

</resources>