<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- JEEVAN — Dark / Night theme override -->
    <style name="Theme.JEEVAN" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <!-- Primary brand color — Emergency Red (slightly brighter in dark) -->
        <item name="colorPrimary">@color/jeevan_red_light</item>
        <item name="colorPrimaryVariant">@color/jeevan_red</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/jeevan_green</item>
        <item name="colorSecondaryVariant">@color/jeevan_green</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Dark background -->
        <item name="android:colorBackground">#FF121212</item>
        <item name="colorSurface">#FF1E1E1E</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorOnBackground">@color/white</item>

        <!-- Error -->
        <item name="colorError">@color/jeevan_red_light</item>
        <item name="colorOnError">@color/white</item>

        <!-- Status & nav bars (dark) -->
        <item name="android:statusBarColor">#FF121212</item>
        <item name="android:navigationBarColor">#FF1E1E1E</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>

        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

</resources>